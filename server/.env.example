# Copy this file to .env and fill in your own values.
# Nothing here talks to Lovable or Supabase anymore - this is your own server.

# Port the API server listens on
PORT=4000

# Origin of your frontend (Vite dev server default shown). Used for CORS.
CLIENT_ORIGIN=http://localhost:8080

# Secret used to sign login sessions (JWTs). Set this to a long random string.
# You can generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-string

# Google Gemini API key (https://aistudio.google.com/apikey)
# Used for document generation, compliance checks, and clause suggestions.
GEMINI_API_KEY=your-gemini-api-key-here

# Which Gemini model to use
GEMINI_MODEL=gemini-2.5-flash

# Resend API key (https://resend.com/api-keys) - used for the "email document" feature.
# Leave blank to disable emailing.
RESEND_API_KEY=your-resend-api-key-here

# The "from" address Resend sends documents from. Must be a verified domain/sender in your
# Resend account, or the sandbox "onboarding@resend.dev" address for testing.
EMAIL_FROM="LexiCloud <onboarding@resend.dev>"
